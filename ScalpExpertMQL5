#include <Trade/Trade.mqh>
CTrade trade;

//---------------- INPUTS
input double Lot = 0.05;
input double TakeProfitUSD = 10.0;
input int MagicNumber = 999111;
input int RSI_Period = 14;
input double RSI_BuyLevel = 50.0;      // خرید اگر RSI زیر این (neutral)
input double RSI_SellLevel = 50.0;     // فروش اگر RSI بالاتر این (neutral)
input int MaxDistance = 150;           // حداکثر فاصله از EMA (points)
input bool UseMACDFilter = false;       // MACD filter enable/disable
input int MACD_Fast = 12;
input int MACD_Slow = 26;
input int MACD_Signal = 9;

//---------------- HANDLES
int ema50_5m;
int ema50_15m, ema200_15m;
int rsi_5m;
int macd_5m;

//+------------------------------------------------------------------+
int OnInit()
{
   ema50_5m  = iMA(_Symbol, PERIOD_M5, 50, 0, MODE_EMA, PRICE_CLOSE);
   ema50_15m  = iMA(_Symbol, PERIOD_M15, 50, 0, MODE_EMA, PRICE_CLOSE);
   ema200_15m = iMA(_Symbol, PERIOD_M15, 200, 0, MODE_EMA, PRICE_CLOSE);
   rsi_5m = iRSI(_Symbol, PERIOD_M5, RSI_Period, PRICE_CLOSE);
   macd_5m = iMACD(_Symbol, PERIOD_M5, MACD_Fast, MACD_Slow, MACD_Signal, PRICE_CLOSE);

   trade.SetExpertMagicNumber(MagicNumber);

   Print("VERSION WITH RSI + MACD STARTED");
   return(INIT_SUCCEEDED);
}

//+------------------------------------------------------------------+
double GetTP(double price, double lot, bool isBuy)
{
   double tickValue = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);

   if(tickValue <= 0)
      tickValue = 1.0;

   // ارزش هر پوینت برای 1 لات
   double valuePerPoint = tickValue / _Point;

   double points = TakeProfitUSD / (lot * valuePerPoint);

   // حداقل فاصله
   if(points < 50) points = 50;

   if(isBuy)
      return price + points * _Point;
   else
      return price - points * _Point;
}

//+------------------------------------------------------------------+
void DrawArrow(string name, datetime time, double price, color clr)
{
   if(ObjectFind(0, name) == -1)
   {
      ObjectCreate(0, name, OBJ_ARROW, 0, time, price);
      ObjectSetInteger(0, name, OBJPROP_COLOR, clr);
   }
}

//+------------------------------------------------------------------+
void OnTick()
{
   static datetime lastBarTime = 0;

   datetime currentBar = iTime(_Symbol, PERIOD_M5, 0);
   if(currentBar == lastBarTime) return;

   lastBarTime = currentBar;

   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);

   if(PositionSelect(_Symbol)) return;

   // TREND
   double ema50_15[], ema200_15[];
   CopyBuffer(ema50_15m, 0, 0, 2, ema50_15);
   CopyBuffer(ema200_15m, 0, 0, 2, ema200_15);

   bool upTrend   = ema50_15[0] > ema200_15[0];
   bool downTrend = ema50_15[0] < ema200_15[0];

   // EMA
   double ema50_5[];
   CopyBuffer(ema50_5m, 0, 0, 1, ema50_5);

   // RSI
   double rsi_5[];
   CopyBuffer(rsi_5m, 0, 0, 1, rsi_5);

   // MACD - از bar 1 استفاده می‌کنیم (کندل بسته)
   double macd_line[], signal_line[], histogram[];
   CopyBuffer(macd_5m, 0, 1, 1, macd_line);      // MACD Line - bar 1
   CopyBuffer(macd_5m, 1, 1, 1, signal_line);    // Signal Line - bar 1
   CopyBuffer(macd_5m, 2, 1, 1, histogram);      // Histogram - bar 1

   // فاصله از EMA
   double distanceBuy  = MathAbs(ask - ema50_5[0]);
   double distanceSell = MathAbs(bid - ema50_5[0]);

   bool nearBuy  = distanceBuy < MaxDistance * _Point;
   bool nearSell = distanceSell < MaxDistance * _Point;

   // RSI Confirmation (neutral 50/50)
   bool rsiGoodForBuy  = rsi_5[0] < RSI_BuyLevel;      
   bool rsiGoodForSell = rsi_5[0] > RSI_SellLevel;    

   // MACD Filter (optional)
   bool macdBullish = !UseMACDFilter || (macd_line[0] > signal_line[0]);
   bool macdBearish = !UseMACDFilter || (macd_line[0] < signal_line[0]);

   // کندل
   double o = iOpen(_Symbol, PERIOD_M5, 1);
   double c = iClose(_Symbol, PERIOD_M5, 1);

   bool bullish = c > o;
   bool bearish = c < o;

   // خالی نگه داریم - لاگ فقط برای سیگنال‌ها

   // BUY
   if(upTrend && nearBuy && rsiGoodForBuy && macdBullish)
   {
      DrawArrow("BUY_"+IntegerToString(currentBar),
                currentBar,
                bid - 20 * _Point,
                clrBlue);

      double tp = GetTP(ask, Lot, true);

      Print(TimeToString(currentBar), " ✅ BUY | Price:", ask, " | RSI:", rsi_5[0], " | TP:", tp);

      trade.Buy(Lot, _Symbol, ask, 0, tp);
   }

   // SELL
   if(downTrend && nearSell && rsiGoodForSell && macdBearish)
   {
      DrawArrow("SELL_"+IntegerToString(currentBar),
                currentBar,
                bid + 20 * _Point,
                clrRed);

      double tp = GetTP(bid, Lot, false);

      Print(TimeToString(currentBar), " 🔻 SELL | Price:", bid, " | RSI:", rsi_5[0], " | TP:", tp);

      trade.Sell(Lot, _Symbol, bid, 0, tp);
   }
}
